        {
          "type": "text",
          "value": "Reemplaza el widget por defecto para cualquier nodo de imagen:"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "markast.buildDocument(\n  context,\n  ast,\n  imageBuilder: (src, {width, height, fit = BoxFit.contain, semanticLabel}) {\n    return CachedNetworkImage(\n      imageUrl: src,\n      width: width,\n      height: height,\n      fit: fit,\n      placeholder: (_, __) => const CircularProgressIndicator(),\n    );\n  },\n)"
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Personalizar el marco"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "themeModifier: (base) => base.copyWith(\n  imageBorderRadius: BorderRadius.circular(12),\n  imageFit: BoxFit.cover,\n)"
    }
  ]
