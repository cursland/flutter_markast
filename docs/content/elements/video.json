    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "markast.buildDocument(\n  context,\n  ast,\n  videoBuilder: (src, {poster, aspectRatio = 16 / 9}) {\n    return VideoPlayerWidget(\n      url: src,\n      thumbnail: poster,\n      aspectRatio: aspectRatio,\n    );\n  },\n)"
    },
