    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Resaltado de sintaxis"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "El resaltado está impulsado por "
        },
        {
          "type": "code_inline",
          "value": "re_highlight"
        },
        {
          "type": "text",
          "value": ". Establece el tema mediante "
        },
        {
          "type": "code_inline",
          "value": "MarkastTheme"
        },
        {
          "type": "text",
          "value": ":"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "final markast = Markast(\n  themeModifier: (base) => base.copyWith(\n    highlightTheme: MarkastHighlightTheme(\n      theme: MarkastCodeThemes.monokai,\n    ),\n  ),\n);"
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "code_inline",
          "value": "MarkastTheme.fromTheme()"
        },
        {
          "type": "text",
          "value": " selecciona automáticamente "
        },
        {
          "type": "code_inline",
          "value": "monokai"
        },
        {
          "type": "text",
          "value": " (oscuro) o "
        },
        {
          "type": "code_inline",
          "value": "xcode"
        },
        {
          "type": "text",
          "value": " (claro) según el brillo de tu app."
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Callback de copiar"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "Por defecto el botón de copiar escribe al portapapeles del sistema. Sobreescríbelo con "
        },
        {
          "type": "code_inline",
          "value": "onCodeCopy"
        },
        {
          "type": "text",
          "value": ":"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "markast.buildDocument(\n  context,\n  ast,\n  onCodeCopy: (code) {\n    Clipboard.setData(ClipboardData(text: code));\n    ScaffoldMessenger.of(context).showSnackBar(\n      const SnackBar(content: Text('¡Copiado!')),\n    );\n  },\n);"
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Deshabilitar el botón de copiar"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "themeModifier: (base) => base.copyWith(\n  codeBlockShowCopyButton: false,\n)"
    }
  ]
}