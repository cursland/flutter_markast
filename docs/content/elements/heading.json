    {
      "type": "code_block",
      "language": "json",
      "value": "{\n  \"type\": \"heading\",\n  \"level\": 2,\n  \"id\": \"instalacion\",\n  \"children\": [{ \"type\": \"text\", \"value\": \"Instalación\" }]\n}"
