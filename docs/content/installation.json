          "value": "markast"
        },
        {
          "type": "text",
          "value": " a tu "
        },
        {
          "type": "code_inline",
          "value": "pubspec.yaml"
        },
        {
          "type": "text",
          "value": ":"
        }
      ]
    },
    {
      "type": "code_block",
