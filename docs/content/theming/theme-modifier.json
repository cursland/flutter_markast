      "children": [
        {
          "type": "text",
          "value": "Usa "
        },
        {
          "type": "code_inline",
          "value": "themeModifier"
        },
        {
          "type": "text",
          "value": " para ajustes. Usa "
        },
        {
          "type": "code_inline",
          "value": "theme"
        },
        {
          "type": "text",
          "value": " solo cuando necesites control total y mantengas el tema tú mismo."
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Objetos anidados"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "Para objetos de tema anidados como "
        },
        {
          "type": "code_inline",
          "value": "MarkastHighlightTheme"
        },
        {
          "type": "text",
          "value": ", construye una nueva instancia directamente:"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "themeModifier: (base) => base.copyWith(\n  highlightTheme: MarkastHighlightTheme(\n    theme: MarkastCodeThemes.monokai,\n  ),\n)"
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Deshabilitar una funcionalidad"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "Pasa "
        },
        {
          "type": "code_inline",
          "value": "null"
        },
        {
          "type": "text",
          "value": " donde la propiedad lo acepta:"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "themeModifier: (base) => base.copyWith(\n  highlightTheme: null, // deshabilita el resaltado de sintaxis\n)"
    }
