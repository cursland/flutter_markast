    {
      "type": "code_block",
      "language": "dart",
      "value": "import 'package:markast/markast.dart';\n\nclass MyHeadingRenderer extends BlockRenderer {\n  const MyHeadingRenderer();\n\n  @override\n  String get type => 'heading';\n\n  @override\n  Widget build(RenderContext ctx, Map<String, dynamic> node) {\n    final level = (node['level'] as int?) ?? 1;\n    final style = switch (level) {\n      1 => ctx.theme.h1TextStyle,\n      2 => ctx.theme.h2TextStyle,\n      _ => ctx.theme.h3TextStyle,\n    };\n    final spans = ctx.markast.buildInlines(\n      ctx,\n      node['children'] as List?,\n      style,\n    );\n    return Padding(\n      padding: ctx.theme.headingPadding,\n      child: Text.rich(TextSpan(style: style, children: spans)),\n    );\n  }\n}"
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "Regístralo en tu instancia de "
        },
        {
          "type": "code_inline",
          "value": "Markast"
        },
        {
          "type": "text",
          "value": ":"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "final markast = Markast()\n  ..registerBlock(const MyHeadingRenderer());"
    },
