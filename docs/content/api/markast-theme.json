    {
      "type": "paragraph",
      "children": [
        {
          "type": "code_inline",
          "value": "MarkastTheme"
        },
        {
          "type": "text",
          "value": " es un "
        },
        {
          "type": "code_inline",
          "value": "ThemeExtension"
        },
        {
          "type": "text",
          "value": " que controla cada aspecto visual de los renderers oficiales. Todos los campos son primitivos de Flutter — no hay clases personalizadas que aprender."
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "value": "Crear un tema"
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "Siempre parte de "
        },
        {
          "type": "code_inline",
          "value": "fromTheme()"
        },
        {
          "type": "text",
          "value": " y sobreescribe lo que necesites:"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "MarkastTheme.fromTheme(Theme.of(context)).copyWith(\n  blockSpacing: 24,\n  listBulletMarker: '▸',\n)"
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "value": "O mediante "
        },
        {
          "type": "code_inline",
          "value": "themeModifier"
        },
        {
          "type": "text",
          "value": " en la instancia de "
        },
        {
          "type": "code_inline",
          "value": "Markast"
        },
        {
          "type": "text",
          "value": ":"
        }
      ]
    },
    {
      "type": "code_block",
      "language": "dart",
      "value": "final markast = Markast(\n  themeModifier: (base) => base.copyWith(blockSpacing: 24),\n);"
    },
